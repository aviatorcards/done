<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Done.</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6">
    <div class="glass w-full max-w-md p-10 rounded-[3rem] shadow-2xl space-y-8">
        <div class="text-center">
            <h1 class="text-4xl font-black text-slate-800 tracking-tight">Reset Password</h1>
            <p class="text-slate-500 text-sm mt-3 font-medium">Enter a new password for <strong>#(email)</strong></p>
        </div>

        <form action="/reset-password" method="POST" class="space-y-6">
            <input type="hidden" name="inviteCode" value="#(token)">
            
            <div class="space-y-2">
                <label class="text-sm font-black text-slate-700 ml-1">New Password</label>
                <input type="password" name="password" required placeholder="••••••••" 
                       class="w-full px-6 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-0 outline-none transition-all font-bold">
            </div>

            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-5 rounded-2xl font-black transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
                Update Password
            </button>
        </form>
        
        <div class="text-center pt-4">
            <a href="/login" class="text-indigo-600 font-black text-sm hover:underline">Back to Login</a>
        </div>
    </div>
</body>
</html>
