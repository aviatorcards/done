<!DOCTYPE html>
<html lang="en" x-data="{ 
    darkMode: localStorage.getItem('darkMode') === 'true',
    isLoggedIn: !!localStorage.getItem('token') && #if(user): true #else: false #endif,
    serverSideAuthenticated: #if(user): true #else: false #endif,
    showSettingsModal: false,
    settingsTab: 'profile',
    cookieAccepted: localStorage.getItem('cookieAccepted') === 'true',
    acceptCookies() {
        this.cookieAccepted = true;
        localStorage.setItem('cookieAccepted', 'true');
    },
    toggleDarkMode() {
        this.darkMode = !this.darkMode;
        localStorage.setItem('darkMode', this.darkMode);
        if (this.darkMode) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    }
}" :class="{ 'dark': darkMode }">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>#(title) - Done.</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <script>
        if (localStorage.getItem('darkMode') === 'true') {
            document.documentElement.classList.add('dark');
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <script src="https://unpkg.com/htmx.org/dist/ext/json-enc.js"></script>
    <script src="https://unpkg.com/alpinejs" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <style>
        [x-cloak] { display: none !important; }
        .glass {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .dark .glass {
            background: rgba(15, 23, 42, 0.85); /* Deep slate-900 tint */
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .dark body {
            background-color: #020617 !important;
        }
    </style>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#f5f3ff', 100: '#ede9fe', 200: '#ddd6fe', 300: '#c4b5fd', 400: '#a78bfa',
                            500: '#8b5cf6', 600: '#7c3aed', 700: '#6d28d9', 800: '#5b21b6', 900: '#4c1d95',
                        },
                        obsidian: {
                            50: '#f8fafc', 100: '#f1f5f9', 200: '#e2e8f0', 300: '#cbd5e1', 400: '#94a3b8',
                            500: '#64748b', 600: '#475569', 700: '#334155', 800: '#1e293b', 900: '#0f172a', 950: '#020617',
                        }
                    }
                }
            }
        }
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.body.addEventListener('htmx:configRequest', (event) => {
                const token = localStorage.getItem('token');
                if (token) event.detail.headers['Authorization'] = `Bearer ${token}`;
            });
            document.body.addEventListener('htmx:responseError', (event) => {
                if (event.detail.xhr.status === 401) {
                    localStorage.removeItem('token');
                    window.location.href = '/';
                }
            });

            // Zombie login detection: If we have a token in localStorage but the server doesn't know us,
            // we should clear the token to avoid showing a broken "logged in" UI.
            const hasLocalToken = !!localStorage.getItem('token');
            const serverAuthenticated = #if(user): true #else: false #endif;
            
            if (hasLocalToken && !serverAuthenticated) {
                console.warn('Zombie login detected: Clearing invalid token.');
                localStorage.removeItem('token');
                window.location.reload();
            }
        });
    </script>
</head>
<body class="bg-indigo-50/30 dark:bg-obsidian-950 text-slate-900 dark:text-slate-100 min-h-screen transition-colors duration-300">
    <nav class="glass sticky top-0 z-50 px-6 py-3 flex justify-between items-center">
        <a href="/" class="flex items-center gap-3 group">
            <img :src="darkMode ? '/images/logo_dark.png' : '/images/logo.png'" alt="Done. Logo" class="w-10 h-10 rounded-xl shadow-lg group-hover:scale-105 transition-transform">
            <span class="text-2xl font-black bg-clip-text text-transparent bg-gradient-to-r from-brand-600 to-indigo-500">Done.</span>
        </a>
        <div class="flex items-center gap-4">
            <button @click="toggleDarkMode()" class="p-2.5 rounded-2xl hover:bg-slate-200/50 dark:hover:bg-obsidian-800/50 transition-all text-slate-600 dark:text-slate-400 hover:text-brand-600 dark:hover:text-brand-400">
                <template x-if="!darkMode">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                    </svg>
                </template>
                <template x-if="darkMode">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.242 16.242l.707.707M7.757 7.757l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                    </svg>
                </template>
            </button>
            
            <template x-if="!isLoggedIn">
                <div class="flex items-center gap-2">
                    <a href="/login" class="px-5 py-2.5 text-sm font-bold text-slate-700 dark:text-zinc-300 hover:text-brand-600 dark:hover:text-brand-400 transition-colors text-center">Sign In</a>
                    <a href="/register" class="px-6 py-2.5 text-sm font-bold bg-brand-600 text-white rounded-2xl hover:bg-brand-700 transition-all shadow-md hover:shadow-lg text-center">Sign Up</a>
                </div>
            </template>
            
            <template x-if="isLoggedIn">
                <div class="flex items-center gap-4">
                    <a href="/boards" class="hidden md:flex items-center gap-2 px-4 py-2 text-sm font-bold text-slate-600 dark:text-slate-300 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                        </svg>
                        My Boards
                    </a>
                    #if(user.isAdmin):
                    <a href="/admin/invites" class="hidden md:flex items-center gap-2 px-4 py-2 text-sm font-bold text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                        Admin Panel
                    </a>
                    #endif
                    <div class="relative" x-data="{ showUserMenu: false }">
                    <button @click="showUserMenu = !showUserMenu" @click.away="showUserMenu = false" 
                            class="flex items-center gap-3 p-1.5 pl-4 rounded-2xl hover:bg-slate-200/50 dark:hover:bg-obsidian-800/50 transition-all border border-transparent hover:border-slate-200 dark:hover:border-obsidian-700 group">
                        <div class="flex flex-col items-end">
                            <span class="text-sm font-bold text-slate-600 dark:text-slate-300 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">#if(user): #if(user.displayName): #(user.displayName) #else: #(user.username) #endif #else: Account #endif</span>
                            #if(user.isEarlyAdopter):
                                <span class="text-[8px] font-black text-amber-500 uppercase tracking-widest">Early Adopter</span>
                            #endif
                        </div>
                        <div class="h-9 w-9 rounded-xl overflow-hidden bg-gradient-to-br from-brand-600 to-indigo-600 flex items-center justify-center text-white text-xs font-black shadow-lg group-hover:scale-105 transition-transform">
                            #if(user):
                                #if(user.avatarUrl):
                                    <img src="#(user.avatarUrl)" alt="Avatar" class="w-full h-full object-cover">
                                #else:
                                    #(user.initials)
                                #endif
                            #endif
                        </div>
                    </button>

                    <!-- User Dropdown Menu -->
                    <div x-show="showUserMenu" 
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 scale-95 translate-y-2"
                         x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                         x-transition:leave="transition ease-in duration-150"
                         x-transition:leave-start="opacity-100 scale-100 translate-y-0"
                         x-transition:leave-end="opacity-0 scale-95 translate-y-2"
                         class="absolute right-0 mt-3 w-56 glass rounded-[2rem] shadow-2xl py-3 z-[100] border border-slate-200/50 dark:border-obsidian-700/50"
                         x-cloak>
                        <div class="px-5 py-3 mb-2 border-b border-slate-100 dark:border-obsidian-800">
                            <div class="flex items-center justify-between mb-1">
                                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Signed in as</p>
                                #if(user):
                                    #if(user.isEarlyAdopter):
                                        <span class="bg-amber-400/10 text-amber-600 dark:text-amber-400 text-[9px] px-2 py-0.5 rounded-md font-black uppercase tracking-widest border border-amber-400/20">Early Adopter</span>
                                    #endif
                                #endif
                            </div>
                            <p class="text-sm font-black text-slate-800 dark:text-white truncate">#if(user): #(user.email) #else: User #endif</p>
                        </div>
                        
                        #if(user):
                        #if(user.isAdmin):
                        <a href="/admin/invites" class="w-full flex items-center gap-3 px-5 py-4 text-sm font-black text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-all text-left">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            Admin Panel
                        </a>
                        #endif
                        #endif

                        <button @click="showSettingsModal = true; showUserMenu = false" class="w-full flex items-center gap-3 px-5 py-4 text-sm font-black text-slate-700 dark:text-zinc-300 hover:text-brand-600 dark:hover:text-brand-400 hover:bg-slate-50 dark:hover:bg-obsidian-800/50 transition-all text-left">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            Settings
                        </button>

                        <div class="mt-2 pt-2 border-t border-slate-100 dark:border-obsidian-800">
                            <button @click="localStorage.removeItem('token'); window.location.href = '/auth/logout'" 
                                    class="w-full flex items-center gap-3 px-5 py-4 text-sm font-black text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all text-left">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                </svg>
                                Sign Out
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </template>
        </div>
    </nav>
    
    <main class="">
        #import("body")
    </main>

    <!-- Settings Modal -->
    <template x-teleport="body">
        <div x-show="showSettingsModal" 
             class="fixed inset-0 z-[200] flex items-center justify-center p-4 bg-obsidian-950/40 backdrop-blur-md"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             x-cloak>
            <div @click.away="showSettingsModal = false" 
                 class="glass w-full max-w-2xl bg-white/95 dark:bg-obsidian-900/95 rounded-[2rem] md:rounded-[3rem] shadow-2xl flex flex-col md:flex-row overflow-hidden border border-white/20 dark:border-white/5 max-h-[90vh] md:max-h-none overflow-y-auto md:overflow-visible"
                 x-transition:enter="transition ease-out duration-300 scale-95 translate-y-4"
                 x-transition:enter-start="opacity-0 scale-95 translate-y-4"
                 x-transition:enter-end="opacity-100 scale-100 translate-y-0">
                
                #if(user):
                <!-- Sidebar -->
                <div class="w-full md:w-64 bg-slate-50 dark:bg-obsidian-950/50 p-4 md:p-8 border-b md:border-b-0 md:border-r border-slate-100 dark:border-obsidian-800 sticky top-0 z-10 md:relative">
                    <h2 class="text-lg md:text-xl font-black text-slate-800 dark:text-white mb-4 md:mb-6">Settings</h2>
                    <nav class="flex md:flex-col gap-2 overflow-x-auto md:overflow-visible pb-2 md:pb-0 scrollbar-hide">
                        <button @click="settingsTab = 'profile'" 
                                :class="settingsTab === 'profile' ? 'bg-brand-600 text-white shadow-lg' : 'text-slate-500 hover:bg-slate-200/50 dark:hover:bg-obsidian-800'"
                                class="whitespace-nowrap flex items-center gap-2 md:gap-3 px-4 py-2 md:py-3 rounded-xl md:rounded-2xl font-bold transition-all text-xs md:text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            Profile
                        </button>
                        <button @click="settingsTab = 'appearance'" 
                                :class="settingsTab === 'appearance' ? 'bg-brand-600 text-white shadow-lg' : 'text-slate-500 hover:bg-slate-200/50 dark:hover:bg-obsidian-800'"
                                class="whitespace-nowrap flex items-center gap-2 md:gap-3 px-4 py-2 md:py-3 rounded-xl md:rounded-2xl font-bold transition-all text-xs md:text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                            </svg>
                            Appearance
                        </button>
                        <button @click="settingsTab = 'privacy'" 
                                :class="settingsTab === 'privacy' ? 'bg-brand-600 text-white shadow-lg' : 'text-slate-500 hover:bg-slate-200/50 dark:hover:bg-obsidian-800'"
                                class="whitespace-nowrap flex items-center gap-2 md:gap-3 px-4 py-2 md:py-3 rounded-xl md:rounded-2xl font-bold transition-all text-xs md:text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                            Privacy
                        </button>
                        <button @click="settingsTab = 'invites'" 
                                :class="settingsTab === 'invites' ? 'bg-brand-600 text-white shadow-lg' : 'text-slate-500 hover:bg-slate-200/50 dark:hover:bg-obsidian-800'"
                                class="whitespace-nowrap flex items-center gap-2 md:gap-3 px-4 py-2 md:py-3 rounded-xl md:rounded-2xl font-bold transition-all text-xs md:text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                            </svg>
                            Invites
                        </button>
                    </nav>
                </div>
                #else:
                <div class="flex flex-col items-center justify-center w-full p-20 text-center space-y-6">
                    <div class="w-20 h-20 bg-slate-100 dark:bg-obsidian-800 rounded-full flex items-center justify-center text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-black text-slate-800 dark:text-white">Sign In Required</h2>
                        <p class="text-slate-600 dark:text-slate-400 font-medium max-w-sm mx-auto mt-2">Your session has expired or you are not signed in. Please log in to your account to view settings.</p>
                    </div>
                    <a href="/login" class="inline-block px-10 py-4 bg-brand-600 text-white rounded-[2rem] font-black text-lg hover:bg-brand-700 transition-all shadow-xl active:scale-95">
                        Sign In Now
                    </a>
                </div>
                #endif

                #if(user):
                <!-- Content -->
                <div class="flex-1 p-5 md:p-12 min-h-[300px] md:min-h-[400px]">
                    <!-- Profile Tab -->
                    <div x-show="settingsTab === 'profile'" class="space-y-8" x-data="{ 
                        email: '#if(user): #(user.email) #endif',
                        displayName: '#if(user): #if(user.displayName): #(user.displayName) #endif #endif',
                        currentPassword: '', 
                        newPassword: '', 
                        confirmPassword: '', 
                        uploading: false,
                        uploadAvatar(el) {
                            const file = el.files[0];
                            if (!file) return;
                            this.uploading = true;
                            const formData = new FormData();
                            formData.append('avatar', file);
                            fetch('/api/users/avatar', {
                                method: 'POST',
                                headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` },
                                body: formData
                            }).then(r => r.ok ? window.location.reload() : alert('Upload failed'))
                              .finally(() => this.uploading = false);
                        },
                        saveProfile() {
                            const data = { email: this.email, displayName: this.displayName };
                            if (this.newPassword) {
                                if (this.newPassword !== this.confirmPassword) return alert('Passwords do not match');
                                data.currentPassword = this.currentPassword;
                                data.newPassword = this.newPassword;
                            }
                            fetch('/api/users/profile', {
                                method: 'PATCH',
                                headers: { 
                                    'Authorization': `Bearer ${localStorage.getItem('token')}`,
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify(data)
                            }).then(async r => {
                                if (r.ok) {
                                    alert('Profile updated!');
                                    window.location.reload();
                                } else {
                                    const err = await r.json();
                                    alert('Failed to update profile: ' + (err.reason || 'Unknown error'));
                                }
                            });
                        }
                    }">
                        <div class="flex items-center gap-4 md:gap-6 p-4 md:p-6 rounded-2xl md:rounded-[2rem] bg-slate-50 dark:bg-obsidian-950/50 border border-slate-100 dark:border-obsidian-800">
                            <div class="relative group cursor-pointer h-16 w-16 md:h-20 md:w-20 rounded-2xl md:rounded-3xl overflow-hidden bg-brand-600 flex items-center justify-center shadow-lg md:shadow-xl">
                                #if(user.avatarUrl):
                                    <img src="#(user.avatarUrl)" alt="Avatar" class="w-full h-full object-cover">
                                #else:
                                    #if(user): #(user.initials) #endif
                                #endif
                                <label class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
                                    <input type="file" class="hidden" accept="image/*" @change="uploadAvatar($event.target)">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </label>
                                <div x-show="uploading" class="absolute inset-0 bg-black/60 flex items-center justify-center z-10">
                                    <div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                                </div>
                            </div>
                            <div>
                                <div class="flex items-center gap-2">
                                    <h3 class="text-lg font-black text-slate-800 dark:text-white">#if(user.displayName): #(user.displayName) #else: #if(user): #(user.username) #endif #endif</h3>
                                    #if(user.isEarlyAdopter):
                                        <span class="bg-amber-400/10 text-amber-600 dark:text-amber-400 text-[10px] px-2 py-0.5 rounded-full font-black uppercase tracking-widest border border-amber-400/20">Early Adopter</span>
                                    #endif
                                </div>
                                <p class="text-sm text-slate-500">#if(user): #(user.email) #endif</p>
                            </div>
                        </div>
                        
                        <div class="space-y-6">
                            <h4 class="text-sm font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 dark:border-obsidian-800 pb-2">Modify Profile</h4>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="space-y-1">
                                    <label class="text-xs font-bold text-slate-400 ml-1">Display Name</label>
                                    <input type="text" placeholder="Your Name" x-model="displayName"
                                           class="w-full px-5 py-3 rounded-2xl bg-white dark:bg-obsidian-800 border border-slate-200 dark:border-obsidian-700 outline-none focus:border-brand-500 transition-all">
                                </div>
                                <div class="space-y-1">
                                    <label class="text-xs font-bold text-slate-400 ml-1">Email Address</label>
                                    <input type="email" placeholder="email@example.com" x-model="email"
                                           class="w-full px-5 py-3 rounded-2xl bg-white dark:bg-obsidian-800 border border-slate-200 dark:border-obsidian-700 outline-none focus:border-brand-500 transition-all">
                                </div>
                            </div>

                            <h4 class="text-sm font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 dark:border-obsidian-800 pb-2 pt-4">Change Password</h4>
                            <div class="space-y-4">
                                <input type="password" placeholder="Current Password" x-model="currentPassword"
                                       class="w-full px-5 py-3 rounded-2xl bg-white dark:bg-obsidian-800 border border-slate-200 dark:border-obsidian-700 outline-none focus:border-brand-500 transition-all">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <input type="password" placeholder="New Password" x-model="newPassword"
                                           class="w-full px-5 py-3 rounded-2xl bg-white dark:bg-obsidian-800 border border-slate-200 dark:border-obsidian-700 outline-none focus:border-brand-500 transition-all">
                                    <input type="password" placeholder="Confirm New Password" x-model="confirmPassword"
                                           class="w-full px-5 py-3 rounded-2xl bg-white dark:bg-obsidian-800 border border-slate-200 dark:border-obsidian-700 outline-none focus:border-brand-500 transition-all">
                                </div>
                            </div>
                            <button @click="saveProfile()" class="w-full md:w-auto bg-brand-600 hover:bg-brand-700 text-white px-8 py-3.5 md:py-3 rounded-2xl font-bold transition-all shadow-lg active:scale-95 disabled:opacity-50" :disabled="!email">
                                Save Profile Changes
                            </button>
                        </div>
                    </div>

                    <!-- Appearance Tab -->
                    <div x-show="settingsTab === 'appearance'" class="space-y-8">
                        <div>
                            <h3 class="text-2xl font-black text-slate-800 dark:text-white">Appearance</h3>
                            <p class="text-slate-500 dark:text-slate-400 mt-1">Customize how Done. looks for you.</p>
                        </div>

                        <div class="space-y-6">
                            <div class="p-6 rounded-3xl bg-slate-50 dark:bg-obsidian-950/50 border border-slate-100 dark:border-obsidian-800 flex items-center justify-between">
                                <div class="flex items-center gap-4">
                                    <div class="h-12 w-12 rounded-2xl bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-brand-600">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-bold text-slate-800 dark:text-white">Dark Mode</p>
                                        <p class="text-xs text-slate-500">Toggle the dark obsidian theme</p>
                                    </div>
                                </div>
                                <button @click="toggleDarkMode()" 
                                        :class="darkMode ? 'bg-brand-600' : 'bg-slate-300 dark:bg-obsidian-700'"
                                        class="w-14 h-8 rounded-full relative transition-colors duration-300 focus:outline-none">
                                    <div :class="darkMode ? 'translate-x-7' : 'translate-x-1'"
                                         class="absolute top-1 left-0 w-6 h-6 bg-white rounded-full transition-transform duration-300 shadow-sm"></div>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Privacy Tab -->
                    <div x-show="settingsTab === 'privacy'" class="space-y-8" x-data="{ 
                        exporting: false,
                        deleting: false,
                        exportData() {
                            this.exporting = true;
                            const token = localStorage.getItem('token');
                            fetch('/api/users/export', {
                                headers: { 'Authorization': `Bearer ${token}` }
                            })
                            .then(resp => {
                                if (!resp.ok) throw new Error();
                                return resp.blob();
                            })
                            .then(blob => {
                                const url = window.URL.createObjectURL(blob);
                                const a = document.createElement('a');
                                a.style.display = 'none';
                                a.href = url;
                                a.download = 'done_data_export.json';
                                document.body.appendChild(a);
                                a.click();
                                window.URL.revokeObjectURL(url);
                            })
                            .catch(() => alert('Export failed'))
                            .finally(() => this.exporting = false);
                        },
                        deleteAccount() {
                            if (confirm('Are you absolutely sure? This will PERMANENTLY delete your account and ALL your boards. This action cannot be undone.')) {
                                this.deleting = true;
                                const token = localStorage.getItem('token');
                                fetch('/api/users/delete', {
                                    method: 'POST',
                                    headers: { 'Authorization': `Bearer ${token}` }
                                })
                                .then(r => {
                                    if (r.ok) {
                                        localStorage.removeItem('token');
                                        window.location.href = '/';
                                    } else {
                                        alert('Failed to delete account');
                                    }
                                })
                                .finally(() => this.deleting = false);
                            }
                        }
                     }">
                        <div>
                            <h3 class="text-2xl font-black text-slate-800 dark:text-white">Data & Privacy</h3>
                            <p class="text-slate-500 dark:text-slate-400 mt-1">Manage your data and account status.</p>
                        </div>

                        <div class="space-y-6">
                            <div class="p-8 rounded-[2rem] bg-slate-50 dark:bg-obsidian-950/50 border border-slate-100 dark:border-obsidian-800 space-y-4">
                                <h4 class="font-black text-slate-800 dark:text-white flex items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    Export Your Data
                                </h4>
                                <p class="text-sm text-slate-500 leading-relaxed font-medium">Download a complete copy of all your boards, columns, cards, and profile information in a portable JSON format. You own your data.</p>
                                <button @click="exportData()" 
                                        :disabled="exporting"
                                        class="w-full md:w-auto bg-white dark:bg-obsidian-800 hover:bg-slate-50 dark:hover:bg-obsidian-700 text-slate-700 dark:text-white px-6 py-3.5 md:py-3 rounded-2xl font-bold border border-slate-200 dark:border-obsidian-700 transition-all shadow-sm hover:shadow-md active:scale-95 flex items-center justify-center gap-2 disabled:opacity-50">
                                    <template x-if="!exporting">
                                        <div class="flex items-center gap-2">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                            </svg>
                                            Download Data (.json)
                                        </div>
                                    </template>
                                    <template x-if="exporting">
                                        <div class="flex items-center gap-2">
                                            <div class="w-4 h-4 border-2 border-brand-600 border-t-transparent rounded-full animate-spin"></div>
                                            Preparing Download...
                                        </div>
                                    </template>
                                </button>
                            </div>

                            <div class="p-8 rounded-[2rem] bg-red-50/50 dark:bg-red-950/10 border border-red-100 dark:border-red-900/30 space-y-4">
                                <h4 class="font-black text-red-600 dark:text-red-500 flex items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                    Danger Zone
                                </h4>
                                <p class="text-sm text-red-600/70 dark:text-red-400/70 leading-relaxed font-medium">Permanently delete your account and all associated data. This action is irreversible.</p>
                                <button @click="deleteAccount()" 
                                        :disabled="deleting"
                                        class="w-full md:w-auto bg-red-600 hover:bg-red-700 text-white px-6 py-3.5 md:py-3 rounded-2xl font-bold transition-all shadow-lg hover:shadow-red-600/20 active:scale-95 disabled:opacity-50">
                                    Close Account Permanently
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Invites Tab -->
                    <div x-show="settingsTab === 'invites'" class="space-y-8" x-data="{
                        inviteEmail: '',
                        sending: false,
                        sendInvite() {
                            if (!this.inviteEmail) return;
                            this.sending = true;
                            fetch('/api/users/invite', {
                                method: 'POST',
                                headers: { 
                                    'Authorization': `Bearer ${localStorage.getItem('token')}`,
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({ email: this.inviteEmail })
                            }).then(async r => {
                                if (r.ok) {
                                    alert('Invite sent! Your friend will receive an email shortly.');
                                    window.location.reload();
                                } else {
                                    const err = await r.json();
                                    alert(err.reason || 'Failed to send invite');
                                }
                            }).finally(() => this.sending = false);
                        }
                    }">
                        <div>
                            <h3 class="text-2xl font-black text-slate-800 dark:text-white tracking-tight">Invite Friends</h3>
                            <p class="text-slate-500 dark:text-slate-400 text-sm font-medium mt-1">Help grow the Done. community. You have <strong>#if(user): #(user.inviteCredits) #endif</strong> credits available.</p>
                        </div>

                        <div class="bg-indigo-50 dark:bg-indigo-900/10 border border-indigo-100 dark:border-indigo-900/30 p-6 rounded-3xl">
                            <div class="flex items-center gap-4 text-indigo-700 dark:text-indigo-300">
                                <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5a2 2 0 10-2 2h2z" />
                                    </svg>
                                </div>
                                <div>
                                    <div class="font-black">Regenerative Invites</div>
                                    <div class="text-sm font-medium opacity-80">You get 1 new invite credit every week (up to 5 max). Use them wisely!</div>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <div class="space-y-2">
                                <label class="text-sm font-black text-slate-700 dark:text-zinc-300 ml-1">Friend's Email Address</label>
                                <div class="flex gap-2">
                                    <input type="email" x-model="inviteEmail" placeholder="friend@example.com" 
                                           class="flex-1 px-6 py-4 rounded-2xl bg-slate-50 dark:bg-obsidian-950/50 border-2 border-slate-100 dark:border-obsidian-800 focus:border-brand-500 focus:ring-0 outline-none transition-all font-bold dark:text-white">
                                    <button @click="sendInvite()" 
                                            :disabled="sending || #if(user): #(user.inviteCredits) #else: 0 #endif === 0"
                                            :class="sending || #if(user): #(user.inviteCredits) #else: 0 #endif === 0 ? 'opacity-50 cursor-not-allowed' : 'hover:scale-105 active:scale-95 shadow-lg'"
                                            class="flex-1 bg-brand-600 text-white px-4 md:px-8 py-4 rounded-2xl font-black transition-all text-sm md:text-base">
                                        <span x-show="!sending">Send Invite</span>
                                        <span x-show="sending">Sending...</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                #endif

                <!-- Close Button -->
                <button @click="showSettingsModal = false" class="absolute top-6 right-6 p-2 text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
    </template>
    <!-- Cookie Consent Banner -->
    <template x-if="!cookieAccepted">
        <div class="fixed bottom-8 right-8 z-[300] max-w-sm w-full mx-4 sm:mx-0 animate-in fade-in slide-in-from-bottom duration-700">
            <div class="glass p-8 rounded-[2.5rem] shadow-2xl border border-white/20 relative overflow-hidden group">
                <div class="absolute -top-12 -right-12 w-32 h-32 bg-brand-500/10 blur-3xl rounded-full group-hover:bg-brand-500/20 transition-colors"></div>
                
                <div class="flex items-start gap-5 relative z-10">
                    <div class="h-12 w-12 rounded-2xl bg-brand-100 dark:bg-brand-900/40 flex items-center justify-center text-brand-600 flex-shrink-0 animate-bounce">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
                        </svg>
                    </div>
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <h3 class="text-lg font-black text-slate-800 dark:text-white leading-tight">We use cookies.</h3>
                            <p class="text-sm text-slate-500 dark:text-slate-400 font-medium leading-relaxed">
                                Our site uses essential cookies for secure authentication and a smoother experience. By using <span class="text-brand-600 font-bold">Done.</span>, you agree to our policies.
                            </p>
                        </div>
                        <button @click="acceptCookies()" 
                                class="w-full bg-brand-600 hover:bg-brand-700 text-white py-3.5 rounded-2xl font-black text-sm transition-all shadow-lg hover:shadow-xl active:scale-95">
                            Got it, thanks!
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </template>
</body>
</html>
