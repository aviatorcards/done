<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>#(title) - Done.</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <script src="https://unpkg.com/htmx.org/dist/ext/json-enc.js"></script>
    <script src="https://unpkg.com/alpinejs" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <style>
        [x-cloak] { display: none !important; }
        .glass {
            background: rgba(255, 255, 255, 0.85); /* Lightened for better light mode reading */
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .dark .glass {
            background: rgba(24, 24, 27, 0.85); /* Much darker and more opaque for better contrast in dark mode */
            border: 1px solid rgba(255, 255, 255, 0.15);
        }
    </style>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#f5f3ff',
                            100: '#ede9fe',
                            200: '#ddd6fe',
                            300: '#c4b5fd',
                            400: '#a78bfa',
                            500: '#8b5cf6',
                            600: '#7c3aed',
                            700: '#6d28d9',
                            800: '#5b21b6',
                            900: '#4c1d95',
                        }
                    }
                }
            }
        }
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Attach JWT token to all HTMX requests
            document.body.addEventListener('htmx:configRequest', (event) => {
                const token = localStorage.getItem('token');
                if (token) {
                    event.detail.headers['Authorization'] = `Bearer ${token}`;
                }
            });

            // Handle unauthorized responses by redirecting to login
            document.body.addEventListener('htmx:responseError', (event) => {
                if (event.detail.xhr.status === 401) {
                    window.location.href = '/login';
                }
            });
        });
    </script>
</head>
<body class="bg-slate-50 dark:bg-zinc-950 text-slate-900 dark:text-zinc-100 min-h-screen transition-colors duration-300" x-data="{ darkMode: false, isLoggedIn: !!localStorage.getItem('token') }" :class="{ 'dark': darkMode }">
    <nav class="glass sticky top-0 z-50 px-6 py-3 flex justify-between items-center">
        <a href="/" class="flex items-center gap-3 group">
            <img src="/images/logo.png" alt="Done. Logo" class="w-10 h-10 rounded-xl shadow-lg group-hover:scale-105 transition-transform">
            <span class="text-2xl font-black bg-clip-text text-transparent bg-gradient-to-r from-brand-600 to-indigo-500">Done.</span>
        </a>
        <div class="flex items-center gap-4">
            <button @click="darkMode = !darkMode" class="p-2.5 rounded-2xl hover:bg-slate-200/50 dark:hover:bg-zinc-800/50 transition-all text-slate-600 dark:text-zinc-400 hover:text-brand-600 dark:hover:text-brand-400">
                <template x-if="!darkMode">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                    </svg>
                </template>
                <template x-if="darkMode">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.242 16.242l.707.707M7.757 7.757l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                    </svg>
                </template>
            </button>
            
            <template x-if="!isLoggedIn">
                <div class="flex items-center gap-2">
                    <a href="/login" class="px-5 py-2.5 text-sm font-bold text-slate-700 dark:text-zinc-300 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Sign In</a>
                    <a href="/register" class="px-6 py-2.5 text-sm font-bold bg-brand-600 text-white rounded-2xl hover:bg-brand-700 transition-all shadow-md hover:shadow-lg">Sign Up</a>
                </div>
            </template>
            
            <template x-if="isLoggedIn">
                <div class="flex items-center gap-4">
                    <button @click="localStorage.removeItem('token'); window.location.href = '/login'" class="text-sm font-bold text-slate-500 hover:text-red-500 dark:hover:text-red-400 transition-colors">Sign Out</button>
                    <div class="h-10 w-10 rounded-2xl bg-gradient-to-br from-brand-600 to-indigo-600 flex items-center justify-center text-white text-xs font-black shadow-lg">#if(user): #(user.initials) #else: U #endif</div>
                </div>
            </template>
        </div>
    </nav>
    
    <main class="p-6">
        #import("body")
    </main>
</body>
</html>
